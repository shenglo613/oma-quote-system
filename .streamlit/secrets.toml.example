# 複製此檔為 secrets.toml 並填入真實值
# secrets.toml 不入 git

[supabase]
url = "https://YOUR_PROJECT.supabase.co"
key = "YOUR_ANON_KEY"

[cookie]
key = "random_32_char_secret_key_here_xx"
name = "oma_auth"
expiry_days = 30

[credentials.usernames.alice]
name = "Alice"
password = "$2b$12$HASHED_PASSWORD_HERE"
role = "staff"

[credentials.usernames.bob]
name = "Bob"
password = "$2b$12$HASHED_PASSWORD_HERE"
role = "manager"
